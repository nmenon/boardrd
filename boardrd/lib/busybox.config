#
# Minimal busybox configuration for boardrd initrd.
#
# Used with: make allnoconfig KCONFIG_ALLCONFIG=<this file>
# Starts from all-disabled, enables only what the init script needs.
#
# Required applets:
#   sh, mount, switch_root  — core init script operation
#   findfs                  — resolve PARTUUID=/UUID=/LABEL= to /dev/ path
#   udhcpc                  — DHCP client for NFS network setup
#   modprobe                — load kernel modules
#   ip                      — network interface/address/route configuration
#   sleep, echo, cat        — init script utilities
#   grep, cut               — cmdline and conf file parsing
#   mkdir, mknod            — /dev setup fallback

CONFIG_BUSYBOX=y
CONFIG_FEATURE_INSTALLER=y

# Static linking — no shared libs needed in initrd
CONFIG_STATIC=y
CONFIG_STATIC_LIBGCC=y

# Shell
CONFIG_ASH=y
CONFIG_ASH_BASH_COMPAT=y
CONFIG_ASH_JOB_CONTROL=n
CONFIG_ASH_ALIAS=n
CONFIG_ASH_GETOPTS=n
CONFIG_ASH_BUILTIN_ECHO=y
CONFIG_ASH_BUILTIN_PRINTF=n
CONFIG_ASH_BUILTIN_TEST=y
CONFIG_HUSH=n

# Filesystem / mount
CONFIG_MOUNT=y
# CONFIG_FEATURE_MOUNT_NFS is not set
CONFIG_FEATURE_MOUNT_FLAGS=y
CONFIG_FEATURE_MOUNT_HELPERS=y
CONFIG_FEATURE_MOUNT_LABEL=y
CONFIG_UMOUNT=y

# Root switching
CONFIG_SWITCH_ROOT=y
CONFIG_PIVOT_ROOT=n

# Device management
CONFIG_MKNOD=y
CONFIG_MKDIR=y

# Module loading
CONFIG_MODPROBE=y
CONFIG_FEATURE_MODPROBE_BLACKLIST=n
CONFIG_DEPMOD=n
CONFIG_INSMOD=y
CONFIG_RMMOD=y
CONFIG_LSMOD=y

# Filesystem utilities
CONFIG_FINDFS=y

# Network
CONFIG_UDHCPC=y
CONFIG_FEATURE_UDHCPC_ARPING=n
CONFIG_FEATURE_UDHCP_RFC3397=n
CONFIG_IP=y
CONFIG_FEATURE_IP_ADDRESS=y
CONFIG_FEATURE_IP_LINK=y
CONFIG_FEATURE_IP_ROUTE=y
CONFIG_FEATURE_IP_TUNNEL=n
CONFIG_FEATURE_IP_RULE=n
CONFIG_FEATURE_IP_SHORT_FORMS=y
CONFIG_IFCONFIG=n
CONFIG_ROUTE=n
# CONFIG_TC is not set

# Text utilities
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_GREP=y
CONFIG_FEATURE_GREP_EGREP_ALIAS=n
CONFIG_CUT=y
CONFIG_SLEEP=y
CONFIG_TIMEOUT=y
CONFIG_PRINTF=n

# Diagnostics
CONFIG_DMESG=y
CONFIG_LS=y
CONFIG_PS=y
CONFIG_FREE=y

# Process / system
CONFIG_SH_IS_ASH=y
CONFIG_BASH_IS_ASH=y
